generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id             String           @id @default(cuid())
  username       String           @unique
  apiKeyHash     String           @unique
  apiKey         String?          // 明文 API Key (仅管理员可见)
  displayName    String?
  avatarUrl      String?
  email          String?          @unique
  isAdmin        Boolean          @default(false)
  status         String           @default("active")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // 好友关系
  receivedFriendships Friendship[] @relation("UserFriends")
  friendOf           Friendship[] @relation("FriendOf")

  // 直接消息 (新)
  directMessagesSent     DirectMessage[] @relation("SentMessages")
  directMessagesReceived DirectMessage[] @relation("ReceivedMessages")

  // 群组
  ownedGroups          Group[]            @relation("GroupOwner")
  groupMemberships     GroupMember[]
  groupMessagesSent    GroupMessage[]     @relation("GroupMessageSender")
}

// 好友关系 (单向关注或双向好友)
model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("pending") // pending, accepted, blocked
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("UserFriends", fields: [userId], references: [id])
  friend User @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([status])
}

// 会话 (支持单聊和群聊，一期先单聊)
model Conversation {
  id              String   @id @default(cuid())
  participantIds  String[]
  lastMessageId   String?   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        Message[] @relation("ConversationMessages")
  lastMessage     Message? @relation(name: "ConversationLastMessage", fields: [lastMessageId], references: [id])
}

// 会话消息 (旧系统，映射到现有表 "Message")
model Message {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  content         String
  contentHtml     String?
  isEdited        Boolean  @default(false)
  editedAt        DateTime?
  deleted         Boolean  @default(false)
  createdAt       DateTime @default(now())

  conversation   Conversation @relation("ConversationMessages", fields: [conversationId], references: [id])
  lastMessageOf  Conversation? @relation(name: "ConversationLastMessage")
  sender         User @relation(fields: [senderId], references: [id])
  reads          MessageRead[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])

  @@map("Message")
}

// 消息已读状态 (旧系统，映射到现有表 "MessageRead")
model MessageRead {
  id         String   @id @default(cuid())
  messageId  String
  userId     String
  readAt     DateTime @default(now())

  message    Message @relation(fields: [messageId], references: [id])
  user       User   @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])

  @@map("MessageRead")
}

// 直接消息 (新系统)
model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String?
  content     String
  sentAt      DateTime @default(now())
  readAt      DateTime?

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User? @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([sentAt])

  @@map("DirectMessage")
}

// 群组
model Group {
  id          String  @id @default(cuid())
  name        String
  description String?
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User            @relation("GroupOwner", fields: [creatorId], references: [id])
  members     GroupMember[]
  messages    GroupMessage[]

  @@index([creatorId])
}

// 群组成员
model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") // admin, member
  joinedAt  DateTime @default(now())

  group     Group  @relation(fields: [groupId], references: [id])
  user      User   @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
}

// 群组消息
model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  content   String
  sentAt    DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id])
  sender    User     @relation("GroupMessageSender", fields: [senderId], references: [id])

  @@index([groupId])
  @@index([sentAt])
}

// 审计日志
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String   // 操作者 (管理员用户ID)
  action     String   // create_user, delete_message, reset_key, etc.
  targetType String   // user, message, conversation, friendship, group
  targetId   String
  details    String?  // JSON 字符串，额外信息
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}