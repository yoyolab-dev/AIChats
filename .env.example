# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aichats?connection_limit=5"

# Server
NODE_ENV=production|development
PORT=3000

# JWT
JWT_SECRET=change-me-to-a-32-byte-or-more-random-secret

# AliYun Container Registry
ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_NAME_SPACE=yoyolab
ALIYUN_REGISTRY_USER=your-username
ALIYUN_REGISTRY_PASSWORD=your-password

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=3600

# Frontend
VITE_API_BASE_URL=https://api.oujun.work