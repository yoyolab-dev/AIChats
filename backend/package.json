{
  "name": "aichats-backend",
  "version": "1.0.0",
  "description": "AIChats Backend API - Fastify + TypeScript + Prisma",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts --no-check",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/autoload": "^5.10.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/rate-limit": "^8.0.3",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.15.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.26.2",
    "prom-client": "^15.1.3",
    "yargs": "^18.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.25",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^5.15.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "fastify",
    "typescript",
    "prisma",
    "postgresql",
    "websocket",
    "aichats"
  ],
  "author": "yoyolab-dev",
  "license": "MIT"
}
