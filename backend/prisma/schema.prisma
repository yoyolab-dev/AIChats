generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  nickname     String?
  apiKey       String   @unique
  role         String   @default("USER") // USER | ADMIN
  avatar       String?
  isOnline     Boolean  @default(false)
  lastSeenAt   DateTime?
  isBanned     Boolean  @default(false)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMessages        Message[]      @relation("SentMessages")
  receivedMessages    Message[]      @relation("ReceivedMessages")
  ownedGroups         Group[]        @relation("GroupOwner")
  groupMemberships    GroupMember[]  @relation("GroupMembership")
  friendships1        Friendship[]   @relation("FriendshipUser1")
  friendships2        Friendship[]   @relation("FriendshipUser2")
  sentGroupMessages   GroupMessage[] @relation("SentGroupMessages")
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING") // PENDING | ACCEPTED | BLOCKED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("FriendshipUser1", fields: [userId], references: [id])
  friend User @relation("FriendshipUser2", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId, status])
  @@index([friendId, status])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  type       String    @default("text") // text | image | file | sticker
  replyToId  String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sender   User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  replyTo  Message?  @relation("ReplyMessage", fields: [replyToId], references: [id])
  replies  Message[] @relation("ReplyMessage")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  avatar      String?
  isPublic    Boolean  @default(false)
  inviteCode  String?  @unique
  maxMembers  Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members GroupMember[] @relation("GroupMembership")
  messages GroupMessage[] @relation("GroupMessages")

  @@index([ownerId])
  @@index([inviteCode])
  @@index([isPublic])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  joinedAt DateTime @default(now())

  group Group @relation("GroupMembership", fields: [groupId], references: [id])
  user  User  @relation("GroupMembership", fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupMessage {
  id        String       @id @default(cuid())
  groupId   String
  senderId  String
  content   String
  type      String       @default("text")
  replyToId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  group   Group         @relation("GroupMessages", fields: [groupId], references: [id])
  sender  User          @relation("SentGroupMessages", fields: [senderId], references: [id])
  replyTo GroupMessage?  @relation("GroupReply", fields: [replyToId], references: [id])
  replies GroupMessage[] @relation("GroupReply")

  @@index([groupId, createdAt])
  @@index([senderId, createdAt])
}
